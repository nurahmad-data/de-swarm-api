# de-swarm API — environment configuration
# Copy to `.env` and edit values before deploying.

# ── HTTP server ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ── Ollama ──────────────────────────────────────────────────────────────────
# URL of the Ollama HTTP API. In docker-compose this is http://ollama:11434
OLLAMA_URL=http://localhost:11434
# Model name as registered in Ollama (run `ollama list` to verify)
OLLAMA_MODEL=de-sql-3b-q8
# HTTP timeout for a single generate call (seconds)
OLLAMA_TIMEOUT_S=60
# Max tokens per response — caps runaway generation
OLLAMA_NUM_PREDICT=300
# Greedy decoding — SQL is deterministic
OLLAMA_TEMPERATURE=0.0

# ── Schemas ─────────────────────────────────────────────────────────────────
# Directory containing <schema_name>.db SQLite files.
# In docker-compose this is /app/data (mounted from host ./data)
SCHEMAS_DIR=./data
# Schema used when caller doesn't specify one in the request
DEFAULT_SCHEMA=ecommerce

# ── Schema RAG (Phase 2.3) ──────────────────────────────────────────────────
# When enabled, the API retrieves only tables relevant to the question
# instead of dumping all tables. Dramatically reduces prompt size on large
# schemas (e.g., SaaS: 16 tables → 4 tables, ~8K chars → ~2K chars).
# Recommended: true for any schema with > 8 tables.
USE_SCHEMA_RAG=false
# Max tables RAG will return. 6 is a good default — balances context
# completeness vs prompt size.
RAG_MAX_TABLES=6

# ── Self-Correction Loop ────────────────────────────────────────────────────
# When the model generates SQL that fails execution, feed the exact SQLite
# error back to the model and retry. Recovers 50-70% of hallucinated-column
# failures. 0=disabled, 1=one retry (recommended), 2=two retries.
SELF_CORRECTION_MAX_RETRIES=1

# ── SQL execution safety ────────────────────────────────────────────────────
QUERY_TIMEOUT_S=5.0
BUSY_TIMEOUT_MS=5000
DEFAULT_ROW_LIMIT=100
MAX_ROW_LIMIT=10000

# ── Auth ────────────────────────────────────────────────────────────────────
# Empty = auth DISABLED (local dev only).
# For any public deploy, generate a strong random key:
#   openssl rand -hex 32
API_KEY=

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for any.
CORS_ORIGINS=*
